<?xml version="1.0"?>
<!--
  line_follower_robot.urdf.xacro  —  4-WHEEL VERSION
  ====================================================
  Layout (top view):

        [front-left]  [front-right]     <- passive, spin freely
             |_____________|
             |   CHASSIS   |   <- blue box, red camera at front looking down
             |_____________|
        [rear-left]   [rear-right]      <- DRIVEN by DiffDrive plugin

  x = forward,  y = left,  z = up
-->
<robot name="line_follower_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ══════════════════════ PROPERTIES ════════════════════════════════════ -->
  <xacro:property name="chassis_length" value="0.22"/>
  <xacro:property name="chassis_width"  value="0.16"/>
  <xacro:property name="chassis_height" value="0.05"/>
  <xacro:property name="chassis_mass"   value="1.0"/>

  <xacro:property name="wheel_radius"   value="0.033"/>
  <xacro:property name="wheel_width"    value="0.026"/>
  <xacro:property name="wheel_mass"     value="0.1"/>
  <xacro:property name="wheel_sep"      value="0.186"/>

  <xacro:property name="front_axle_x"  value="0.07"/>
  <xacro:property name="rear_axle_x"   value="-0.07"/>
  <xacro:property name="base_z"         value="${wheel_radius}"/>

  <!-- ══════════════════════ MATERIALS ═════════════════════════════════════ -->
  <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
  <material name="blue" ><color rgba="0.2 0.4 0.8 1.0"/></material>
  <material name="red"  ><color rgba="0.8 0.1 0.1 1.0"/></material>

  <!-- ══════════════════════ INERTIA MACROS ════════════════════════════════ -->
  <xacro:macro name="box_inertia" params="m l w h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(w*w+h*h)/12}" ixy="0" ixz="0"
               iyy="${m*(l*l+h*h)/12}" iyz="0"
               izz="${m*(l*l+w*w)/12}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0"
               iyy="${m*(3*r*r+h*h)/12}" iyz="0"
               izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <!-- ══════════════════════ BASE LINK ═════════════════════════════════════ -->
  <link name="base_link"/>

  <!-- ══════════════════════ CHASSIS ═══════════════════════════════════════ -->
  <link name="chassis">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="${chassis_length} ${chassis_width} ${chassis_height}"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="${chassis_length} ${chassis_width} ${chassis_height}"/></geometry>
    </collision>
    <xacro:box_inertia m="${chassis_mass}" l="${chassis_length}" w="${chassis_width}" h="${chassis_height}"/>
  </link>

  <joint name="base_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child  link="chassis"/>
    <origin xyz="0 0 ${base_z + chassis_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ══════════════════════ WHEEL MACRO ═══════════════════════════════════ -->
  <xacro:macro name="wheel" params="name reflect x_off">
    <link name="${name}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="chassis"/>
      <child  link="${name}_wheel"/>
      <origin xyz="${x_off} ${reflect * wheel_sep/2} ${-chassis_height/2}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- Front wheels (passive — spin freely) -->
  <xacro:wheel name="front_left"  reflect=" 1" x_off="${front_axle_x}"/>
  <xacro:wheel name="front_right" reflect="-1" x_off="${front_axle_x}"/>

  <!-- Rear wheels (driven by DiffDrive) -->
  <xacro:wheel name="rear_left"   reflect=" 1" x_off="${rear_axle_x}"/>
  <xacro:wheel name="rear_right"  reflect="-1" x_off="${rear_axle_x}"/>

  <!-- ══════════════════════ CAMERA ════════════════════════════════════════ -->
  <link name="camera_link">
    <visual>
      <geometry><box size="0.020 0.030 0.012"/></geometry>
      <material name="red"/>
    </visual>
    <collision>
      <geometry><box size="0.020 0.030 0.012"/></geometry>
    </collision>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <!-- Camera mounted near the front, pitched downward a bit so the
       optical axis sees forward+down. This gives the vision node a
       short look-ahead on the track while still seeing the area
       immediately below the robot. Calculations in the node assume
       a relatively low-resolution image (160x120) so we keep that.
  -->
  <joint name="camera_joint" type="fixed">
    <parent link="chassis"/>
    <child  link="camera_link"/>
    <!-- place camera near front of chassis, slightly above the chassis
         midline so the lens is ~7cm above the ground for good perspective -->
    <origin xyz="${chassis_length/2 - 0.02} 0 ${chassis_height/2 - 0.01}" rpy="0 -1.0472 0"/>
  </joint>

  <!-- ══════════════════════ GAZEBO PLUGINS ════════════════════════════════ -->

  <!-- DiffDrive: rear wheels only -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>${wheel_sep}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <odom_publish_frequency>30</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>
  </gazebo>

  <!-- Joint states for all 4 wheels -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <joint_name>front_left_wheel_joint</joint_name>
      <joint_name>front_right_wheel_joint</joint_name>
      <joint_name>rear_left_wheel_joint</joint_name>
      <joint_name>rear_right_wheel_joint</joint_name>
      <topic>joint_states</topic>
      <update_rate>30</update_rate>
    </plugin>
  </gazebo>

  <!-- Downward camera -->
  <gazebo reference="camera_link">
    <sensor name="line_camera" type="camera">
          <!-- sensor pose relative to camera_link: keep centered on the link
            and rely on the joint rotation/offset above for aiming -->
          <pose>0 0 0 0 0 0</pose>
      <always_on>1</always_on>
      <update_rate>15</update_rate>
      <camera name="line_camera">
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>160</width>
          <height>120</height>
          <format>RGB_INT8</format>
        </image>
        <clip><near>0.02</near><far>2.0</far></clip>
        <noise><type>gaussian</type><mean>0.0</mean><stddev>0.005</stddev></noise>
      </camera>
      <topic>/line_camera/image</topic>
      <gz_frame_id>camera_link</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- Friction -->
  <gazebo reference="rear_left_wheel"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>
  <gazebo reference="rear_right_wheel"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>
  <gazebo reference="front_left_wheel"><mu1>0.8</mu1><mu2>0.8</mu2></gazebo>
  <gazebo reference="front_right_wheel"><mu1>0.8</mu1><mu2>0.8</mu2></gazebo>

</robot>
